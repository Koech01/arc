# Database
POSTGRES_DB=arc_mono_db
POSTGRES_USER=arc_mono_user
POSTGRES_PASSWORD=arc_mono_password

ConnectionStrings__PostgreSQL=Host=localhost;Port=5432;Database=arc_mono_db;Username=arc_mono_user;Password=arc_mono_password

# JWT 
# For production, replace with: openssl rand -base64 32
Jwt__SecretKey=dev-secret-key-change-in-production-at-least-32-characters-long
Jwt__Issuer=Arc
Jwt__Audience=Arc
Jwt__ExpirationMinutes=480

# Admin seed account 
AdminAccount__Enabled=true
AdminAccount__Username=admin
AdminAccount__Email=admin@arc.com
AdminAccount__Password=Str0ng#Arc$99

# Frontend: pre-fill demo credentials on the login page (portfolio deployments)
ENABLE_DEMO_LOGIN_PREFILL=false

# Demo workspace: auto-seed on startup when demo user is missing (set true for portfolio)
DemoWorkspace__Enabled=false
# Demo workspace: force full reseed on next startup (remove after one restart)
DemoWorkspace__ForceReseed=false

# LLM (optional)
LLM__DefaultBaseUrl=
LLM__DefaultModel=
LLM__DefaultApiKey=
LLM__DefaultEndpoint=chat/completions
LLM__DefaultAuthType=bearer