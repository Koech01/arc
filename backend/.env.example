# Arc Environment Configuration

# Database Configuration
ConnectionStrings__PostgreSQL=Host=localhost;Port=5432;Database=<database>;Username=<username>;Password=<password>

# JWT Configuration
Jwt__SecretKey=dev-secret-key-change-in-production-at-least-32-characters-long
Jwt__Issuer=Arc
Jwt__Audience=Arc
Jwt__ExpirationMinutes=60

# Admin Account (Optional - for initial setup)
AdminAccount__Enabled=true
AdminAccount__Username=admin
AdminAccount__Email=admin@arc.com
AdminAccount__Password=Str0ng#Arc$99

# LLM Configuration (Optional - system defaults)
LLM__DefaultBaseUrl=
LLM__DefaultModel=
LLM__DefaultApiKey=
LLM__DefaultEndpoint=chat/completions
LLM__DefaultAuthType=bearer

# Logging
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning